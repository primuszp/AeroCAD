<Window x:Class="Primusz.AeroCAD.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:drawing="clr-namespace:Primusz.AeroCAD.Core.Drawing;assembly=AeroCAD.Core"
        xmlns:controls="clr-namespace:Primusz.AeroCAD.View.Controls"
        Title="AeroCAD" Height="600" Width="900">
    <Window.Resources>
        <Style x:Key="HorizontalBevelGrip" TargetType="{x:Type controls:DockPanelSplitter}">
            <Setter Property="Thickness" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:DockPanelSplitter}">
                        <Grid ToolTip="Resize" SnapsToDevicePixels="True" Background="LightGray">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Margin="2,0,2,0" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                            </StackPanel>
                            <Border BorderBrush="#5AFFFFFF" BorderThickness="0,1,0,0"/>
                            <Border BorderBrush="#5A000000" BorderThickness="0,0,0,1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VerticalBevelGrip" TargetType="{x:Type controls:DockPanelSplitter}">
            <Setter Property="Thickness" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:DockPanelSplitter}">
                        <Grid ToolTip="Resize" SnapsToDevicePixels="True" Background="LightGray">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Margin="0,2,0,2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                            </StackPanel>
                            <Border BorderBrush="#5AFFFFFF" BorderThickness="1,0,0,0"/>
                            <Border BorderBrush="#5A000000" BorderThickness="0,0,1,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for sub-menu items bound to MenuItemViewModel -->
        <Style x:Key="CatalogMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Header" Value="{Binding Label}"/>
            <Setter Property="Command" Value="{Binding Command}"/>
        </Style>

        <!-- Style for top-level menu groups bound to MenuGroupViewModel -->
        <Style x:Key="CatalogMenuGroupStyle" TargetType="MenuItem">
            <Setter Property="Header" Value="{Binding GroupName}"/>
            <Setter Property="ItemsSource" Value="{Binding Items}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CatalogMenuItemStyle}"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Height="Auto" Width="Auto">
            <StatusBarItem>
                <TextBlock x:Name="status" Text="{Binding StatusText}" MinWidth="180"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveToolName}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="ORTHO"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOrthoActive}" Value="True">
                                    <Setter Property="Foreground" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="GRID"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGridVisible}" Value="True">
                                    <Setter Property="Foreground" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Menu is fully data-driven from MenuGroups (built from the command catalog).
             Adding a plugin with CreateCommands() + menuGroup automatically adds a menu entry. -->
        <Menu DockPanel.Dock="Top"
              ItemsSource="{Binding MenuGroups}"
              ItemContainerStyle="{StaticResource CatalogMenuGroupStyle}"/>

        <controls:CommandLineControl x:Name="CommandInput"
                                     DockPanel.Dock="Bottom"
                                     DataContext="{Binding CommandLine}"
                                     Height="Auto"
                                     Width="Auto"
                                     MinHeight="45"
                                     MaxHeight="110"
                                     FontFamily="Courier New"
                                     FontSize="15"
                                     VerticalContentAlignment="Stretch"/>
        <controls:DockPanelSplitter DockPanel.Dock="Bottom"
                                    Style="{StaticResource HorizontalBevelGrip}"/>
        <drawing:Viewport x:Name="Viewport"
                          DockPanel.Dock="Top"
                          Background="#FF212830"
                          Focusable="True"
                          Zoom="1"/>
    </DockPanel>
</Window>
