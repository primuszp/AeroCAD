<Window x:Class="Primusz.AeroCAD.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:drawing="clr-namespace:Primusz.AeroCAD.Core.Drawing;assembly=AeroCAD.Core"
        xmlns:controls="clr-namespace:Primusz.AeroCAD.View.Controls"
        xmlns:converters="clr-namespace:Primusz.AeroCAD.View.Converters"
        xmlns:controls2="clr-namespace:Primusz.AeroCAD.View.Controls"
        Title="AeroCAD" Height="600" Width="900">
    <Window.Resources>
        <DataTemplate x:Key="LineWeightItemTemplate">
            <TextBlock Text="{Binding StringFormat=LW {0:0.##}}"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
        </DataTemplate>
        <Style x:Key="HorizontalBevelGrip" TargetType="{x:Type controls:DockPanelSplitter}">
            <Setter Property="Thickness" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:DockPanelSplitter}">
                        <Grid ToolTip="Resize" SnapsToDevicePixels="True" Background="LightGray">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Margin="2,0,2,0" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                            </StackPanel>
                            <Border BorderBrush="#5AFFFFFF" BorderThickness="0,1,0,0"/>
                            <Border BorderBrush="#5A000000" BorderThickness="0,0,0,1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VerticalBevelGrip" TargetType="{x:Type controls:DockPanelSplitter}">
            <Setter Property="Thickness" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:DockPanelSplitter}">
                        <Grid ToolTip="Resize" SnapsToDevicePixels="True" Background="LightGray">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Margin="0,2,0,2" Fill="#5A000000"/>
                                <Rectangle Width="2" Height="2" Fill="#5A000000"/>
                            </StackPanel>
                            <Border BorderBrush="#5AFFFFFF" BorderThickness="1,0,0,0"/>
                            <Border BorderBrush="#5A000000" BorderThickness="0,0,1,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for sub-menu items bound to MenuItemViewModel -->
        <Style x:Key="CatalogMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Header" Value="{Binding Label}"/>
            <Setter Property="Command" Value="{Binding Command}"/>
        </Style>

        <!-- Style for top-level menu groups bound to MenuGroupViewModel -->
        <Style x:Key="CatalogMenuGroupStyle" TargetType="MenuItem">
            <Setter Property="Header" Value="{Binding GroupName}"/>
            <Setter Property="ItemsSource" Value="{Binding Items}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CatalogMenuItemStyle}"/>
        </Style>

        <!-- Toolbar button style for MenuItemViewModel -->
        <DataTemplate x:Key="ToolbarButtonTemplate">
            <Button Content="{Binding DisplayLabel}"
                    Command="{Binding Command}"
                    ToolTip="{Binding Label}"
                    Padding="6,2"
                    Margin="1,0"/>
        </DataTemplate>

        <!-- Toolbar group template: buttons for each item + separator after the group -->
        <DataTemplate x:Key="ToolbarGroupTemplate">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding Items}"
                              ItemTemplate="{StaticResource ToolbarButtonTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Separator Margin="2,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LayerComboItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Content="💡"
                              ToolTip="Visible"
                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                              Style="{DynamicResource LayerVisibleToggleButtonStyle}"
                              Margin="0,0,2,0"/>
                <ToggleButton Content="❄"
                              ToolTip="Frozen"
                              IsChecked="{Binding IsFrozen, Mode=TwoWay}"
                              Style="{DynamicResource LayerFrozenToggleButtonStyle}"
                              Margin="0,0,2,0"/>
                <ToggleButton Content="🔒"
                              ToolTip="Locked"
                              IsChecked="{Binding IsLocked, Mode=TwoWay}"
                              Style="{DynamicResource LayerLockedToggleButtonStyle}"
                              Margin="0,0,4,0"/>
                <!-- Color swatch -->
                <Rectangle Width="12" Height="12"
                           Fill="{Binding ColorBrush}"
                           Stroke="#FF000000"
                           StrokeThickness="0.5"
                           Margin="0,0,6,0"/>
                <!-- Layer name -->
                <TextBlock Text="{Binding Name}"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                           FontWeight="SemiBold"
                           MinWidth="80"/>
                <!-- Line weight -->
                <TextBlock Text="{Binding LineWeight, StringFormat=LW {0:0.##}}"
                           Foreground="#FF9AA4B2"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </DataTemplate>

        <Style x:Key="LayerComboItemContainerStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="LayerVisibleToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FFFFE08A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayerFrozenToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FF6BB5FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayerLockedToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FFFFD700"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Height="Auto" Width="Auto">
            <StatusBarItem>
                <TextBlock x:Name="status" Text="{Binding StatusText}" MinWidth="180"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveToolName}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="ORTHO"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOrthoActive}" Value="True">
                                    <Setter Property="Foreground" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="GRID"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGridVisible}" Value="True">
                                    <Setter Property="Foreground" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Menu: fully data-driven from MenuGroups. Plugin commands appear automatically. -->
        <Menu DockPanel.Dock="Top"
              ItemsSource="{Binding MenuGroups}"
              ItemContainerStyle="{StaticResource CatalogMenuGroupStyle}"/>

        <!-- Toolbar: same catalog source, excludes File and View groups. -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <ItemsControl ItemsSource="{Binding ToolbarGroups}"
                              ItemTemplate="{StaticResource ToolbarGroupTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ToolBar>
            <ToolBar>
                <TextBlock Text="Layer"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <ComboBox Width="260"
                          ItemsSource="{Binding Layers}"
                          SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
                          ItemTemplate="{StaticResource LayerComboItemTemplate}"
                          ItemContainerStyle="{StaticResource LayerComboItemContainerStyle}"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                          Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                          Padding="4,2"
                          Margin="0,0,8,0"/>
                <Button Content="New"
                        Command="{Binding AddLayerCommand}"
                        Margin="0,0,8,0"
                        Padding="10,2"/>
                <Button Content="Move Sel"
                        Command="{Binding MoveSelectionToLayerCommand}"
                        Margin="0,0,8,0"
                        Padding="10,2"/>
                <Button Content="Remove"
                        Command="{Binding RemoveLayerCommand}"
                        Margin="0,0,8,0"
                        Padding="10,2"/>
                <TextBlock Text="LW"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <ComboBox Width="90"
                          ItemsSource="{Binding LayerLineWeights}"
                          SelectedItem="{Binding SelectedLayer.LineWeight, Mode=TwoWay}"
                          ItemTemplate="{StaticResource LineWeightItemTemplate}"
                          Margin="0,0,8,0"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                          Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                          Padding="4,2"/>
                <TextBlock Text="Color"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <controls2:AciColorPicker Width="32"
                                          Height="24"
                                          SelectedColorIndex="{Binding SelectedLayer.ColorIndex, Mode=TwoWay}"
                                          Margin="0,0,8,0"/>
                <ComboBox Width="110"
                          ItemsSource="{Binding LayerLineStyles}"
                          SelectedItem="{Binding SelectedLayer.LineStyle, Mode=TwoWay}"
                          Margin="0,0,8,0"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                          Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                          Padding="4,2"/>
            </ToolBar>
        </ToolBarTray>

        <controls:CommandLineControl x:Name="CommandInput"
                                     DockPanel.Dock="Bottom"
                                     DataContext="{Binding CommandLine}"
                                     Height="Auto"
                                     Width="Auto"
                                     MinHeight="45"
                                     MaxHeight="110"
                                     FontFamily="Courier New"
                                     FontSize="15"
                                     VerticalContentAlignment="Stretch"/>
        <controls:DockPanelSplitter DockPanel.Dock="Bottom"
                                    Style="{StaticResource HorizontalBevelGrip}"/>
        <drawing:Viewport x:Name="Viewport"
                          DockPanel.Dock="Top"
                          Background="#FF212830"
                          Focusable="True"
                          Zoom="1"/>
    </DockPanel>
</Window>
