<UserControl x:Class="Primusz.AeroCAD.View.Controls.AciColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Primusz.AeroCAD.View.Converters"
             Height="Auto"
             Width="Auto">
    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
    </UserControl.Resources>
    <Grid>
        <Button x:Name="PickerButton"
                Click="OpenPicker_Click"
                Padding="4,2"
                Background="{Binding SelectedColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorToBrushConverter}}"
                BorderBrush="#FF3B4657"
                Width="28"
                Height="24">
            <Rectangle Width="16" Height="10" Stroke="#FF1A1F26" StrokeThickness="0.5"/>
        </Button>
        <Popup x:Name="PickerPopup"
               PlacementTarget="{Binding ElementName=PickerButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"/>
    </Grid>
</UserControl>
